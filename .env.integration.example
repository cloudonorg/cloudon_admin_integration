APP_MODULE_CODE=pharmacy_one

DJANGO_API_URL=https://devadminpanel.cloudon.gr
DJANGO_API_USER=admin
DJANGO_API_PASSWORD=change_me

SYNC_KEY=change_me

ADMIN_PANEL_CLIENT_TOKEN_PATH=/api/client-auth/token/
ADMIN_PANEL_AUTHORIZATION_PATH=/api/authorization/
ADMIN_PANEL_RUNNING_LICENSES_PATH=/api/licenses/running/
ADMIN_PANEL_MODULE_SETTINGS_PATH=/api/module-settings/
ADMIN_PANEL_MODULES_PATH=/api/modules/
ADMIN_PANEL_COMPANIES_PATH=/api/companies/
ADMIN_PANEL_COMPANY_API_CLIENTS_PATH=/api/company-api-clients/

ADMIN_PANEL_JWT_ALGORITHM=HS256
ADMIN_PANEL_JWT_SIGNING_KEY=change_me
# ADMIN_PANEL_JWT_PUBLIC_KEY=
# ADMIN_PANEL_JWT_AUDIENCE=

HTTP_TIMEOUT_SECONDS=10
SYNC_ON_STARTUP=true
ALLOW_TOKEN_PROXY=true
ENFORCE_TOKEN_MODULE_MATCH=true
CACHE_ALL_MODULES=true
ADMIN_PANEL_LICENSE_EXTENSION_DAYS=10
INTEGRATION_WRAP_RESPONSES=true
INTEGRATION_EXCLUDED_PATHS=/docs,/redoc,/openapi.json,/favicon.ico

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
REDIS_KEY_PREFIX=pharmacyone:integration
